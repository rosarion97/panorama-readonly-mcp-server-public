# Template for the plaintext "Option B" setup. The RECOMMENDED path (Option A)
# keeps secrets in the Docker/Podman secret store instead of this file — see the
# README. Use this file only if you run the container directly with
# `--env-file`: copy it to `.env`, fill in real values, and `chmod 600 .env`.
#
# Do NOT commit a real API key (.env is git-ignored), and never paste these
# values into Claude Desktop's config file.

# Hostname or IP address of your Panorama management server.
PANORAMA_HOST=panorama.example.com

# PAN-OS API key. Generate it out of band with curl (see README, Step 0).
PANORAMA_API_KEY=replace-with-your-key

# TLS verification:
#   yes (default) — verify Panorama's TLS certificate
#   no            — skip verification; only acceptable for self-signed lab certs
PANORAMA_VERIFY_SSL=yes
